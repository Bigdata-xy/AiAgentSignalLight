<Window x:Class="SignalLight.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="100"
        Height="220"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True">
    <Grid x:Name="Root">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top">
        <Border x:Name="Body"
                Width="80"
                Height="200"
                CornerRadius="24"
                Background="#2B2B2B"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                MouseLeftButtonDown="Body_MouseLeftButtonDown">
            <Border.Effect>
                <DropShadowEffect Color="#111111" BlurRadius="18" ShadowDepth="4" Opacity="0.55" />
            </Border.Effect>

            <Grid Margin="0,8,0,6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Grid x:Name="RedLampHost" Width="64" Height="48" Margin="0,1">
                        <Ellipse x:Name="RedRing" Width="44" Height="44" Opacity="0" IsHitTestVisible="False"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <Ellipse x:Name="RedWell" Width="44" Height="44" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Ellipse x:Name="RedLamp" Width="34" Height="34" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>

                    <Grid x:Name="YellowLampHost" Width="64" Height="48" Margin="0,1">
                        <Ellipse x:Name="YellowRing" Width="44" Height="44" Opacity="0" IsHitTestVisible="False"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <Ellipse x:Name="YellowWell" Width="44" Height="44" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Ellipse x:Name="YellowLamp" Width="34" Height="34" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>

                    <Grid x:Name="GreenLampHost" Width="64" Height="48" Margin="0,1">
                        <Ellipse x:Name="GreenRing" Width="44" Height="44" Opacity="0" IsHitTestVisible="False"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                        <Ellipse x:Name="GreenWell" Width="44" Height="44" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Ellipse x:Name="GreenLamp" Width="34" Height="34" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>

                <Border x:Name="SessionCountBadge"
                        MinWidth="24"
                        Height="14"
                        CornerRadius="8"
                        Background="#FF9F0A"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,4,4"
                        Panel.ZIndex="10"
                        MouseLeftButtonDown="SessionCountBadge_MouseLeftButtonDown"
                        Visibility="Collapsed">
                    <TextBlock x:Name="SessionCountText"
                               Text="0"
                               FontSize="9"
                               FontWeight="Bold"
                               Foreground="#171717"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="4,0" />
                </Border>
            </Grid>
        </Border>

        <Border x:Name="SessionDrawer"
                Width="252"
                Height="200"
                CornerRadius="18"
                Background="#F7202124"
                Margin="10,8,0,0"
                Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect Color="#111111" BlurRadius="24" ShadowDepth="6" Opacity="0.35" />
            </Border.Effect>
            <Grid>
                <Border Width="3"
                        Height="148"
                        CornerRadius="0,4,4,0"
                        Background="#FF9F0A"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center" />
                <StackPanel Margin="10,9,10,9">
                    <Grid Margin="4,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="当前任务"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="12" />
                        <TextBlock x:Name="SessionDrawerSortLabel"
                                   Grid.Column="1"
                                   Text="按优先级"
                                   Foreground="#A8A8B0"
                                   FontSize="10" />
                    </Grid>
                    <Border Height="1" Background="#22FFFFFF" Margin="0,0,0,1" />
                    <ScrollViewer Height="150"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  PanningMode="VerticalOnly">
                        <StackPanel x:Name="SessionListPanel" />
                    </ScrollViewer>
                </StackPanel>
            </Grid>
        </Border>
        </StackPanel>
    </Grid>
</Window>
